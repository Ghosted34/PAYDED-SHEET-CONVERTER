{
  "name": "navy-converter_stdnle",
  "version": "1.0.0",
  "description": "Standalone multi-class payroll adjustment/converter batch upload service",
  "keywords": [
    "adjustment",
    "navy",
    "payroll",
    "converter",
    "excel",
    "csv"
  ],
  "license": "ISC",
  "author": "Victor",
  "type": "module",
  "main": "server.js",
  "pkg": {
    "assets": [
      "public/**/*",
      "src/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "build": {
    "appId": "com.company.excel-processor",
    "productName": "Excel Processor",
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "files": [
      "electron.js",
      "server.js",
      "src/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "public"
      }
    ]
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pkg:test": "pkg server.js --targets node18-win-x64 --output test.exe",
    "pkg:build": "pkg server.js --targets node18-win-x64 --output navy-converter.exe",
    "nexe:test": "nexe server.js -t windows-x64-18.0.0 -o test.exe",
    "nexe:build": "nexe server.js -t windows-x64-18.0.0 -o navy-converter.exe",
    "electron:test": "electron-packager . navy-converter --platform=win32 --arch=x64 --out=dist --overwrite --prune=true --ignore=node_modules/electron-packager|node_modules/electron",
    "electron:build": "electron-packager . navy-converter --platform=win32 --arch=x64 --out=dist --overwrite --prune=true --ignore=node_modules/electron-packager|node_modules/electron"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.2.1",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "mssql": "^11.0.1",
    "multer": "^2.0.2",
    "tailwind-scrollbar-hide": "^4.0.0",
    "serve-index": "^1.9.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18"
  }
}
